# Alpha GYM API — variáveis de ambiente
# Copie para .env e preencha

PORT=3001
NODE_ENV=development

# Banco SQLite (pasta data/ no projeto; opcional: SQLITE_PATH=/caminho/absoluto)
# SQLITE_PATH=data

# JWT (use openssl rand -base64 32 em produção)
JWT_SECRET=altere-em-producao-use-base64-32-chars
JWT_EXPIRES_IN=7d

# CORS — origens permitidas (vírgula para várias). Frontend Alpha = 5173, Command Center = 8080.
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080
